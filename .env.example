# SupplyShock — Environment Variables
# Copy this file to .env and fill in the values

# ── Auth (Clerk) ──
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWKS_URL=                          # optional — auto-derived from publishable key

# ── Frontend (Vite — must start with VITE_) ──
VITE_CLERK_PUBLISHABLE_KEY=
VITE_API_BASE_URL=http://localhost:8000

# ── Payments (Stripe) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── AI / LLM ──
CLAUDE_API_KEY=

# ── Data Sources ──
AISSTREAM_API_KEY=
EIA_API_KEY=
COMTRADE_API_KEY=

# ── Database ──
DATABASE_URL=postgresql+asyncpg://supplyshock:supplyshock_dev@db:5432/supplyshock
DATABASE_URL_SYNC=postgresql://supplyshock:supplyshock_dev@db:5432/supplyshock
SUPPLYSHOCK_DB_URL=postgresql://supplyshock:supplyshock_dev@db:5432/supplyshock

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Email ──
RESEND_API_KEY=

# ── Monitoring ──
SENTRY_DSN=

# ── Simulation (Zep) ──
ZEP_API_KEY=

# ── Backup (S3-compatible) ──
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
